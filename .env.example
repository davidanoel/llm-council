MODEL_PROVIDER=internal
DISABLE_EXTERNAL_CALLS=false

# Optional internal provider bearer token. Do not hardcode secrets.
INTERNAL_MODEL_API_KEY=

# Optional Claude token override. Otherwise gcloud generates one at runtime.
ANTHROPIC_BEARER_TOKEN=

# Internal A2A JWT fallback used when INTERNAL_MODEL_API_KEY is empty.
ENV=DEV
APP_ID=
VERSION=
SECRET_DEV=
JWT_TOKEN_URL_DEV=

COUNCIL_MODELS=chatgpt-5.1,gemini-3.1-pro,claude-sonnet-4.5
MODEL_REGISTRY_JSON={"chatgpt-5.1":{"url":"https://ewp.aexp.com/chatgpt-5.1","family":"openai"},"gemini-3.1-pro":{"url":"https://ewp.aexp.com/gemini-3.1-pro","family":"gemini"},"claude-sonnet-4.5":{"url":"https://ewp.aexp.com/claude-sonnet-4.5","family":"anthropic"}}

# Local SQLite storage.
ANNOTATION_DB_PATH=data/annotations.db
